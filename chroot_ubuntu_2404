 chroot /opt/starfish-demo/ /bin/bash

 # 1) Make sure the tools exist
 apt update
 apt install -y locales

 # 2) Enable the locales you want (safe to run even if already enabled)
 sed -i -E 's/^[# ]*(en_US\.UTF-8 UTF-8)/\1/' /etc/locale.gen
 sed -i -E 's/^[# ]*(en_GB\.UTF-8 UTF-8)/\1/' /etc/locale.gen
 sed -i -E 's/^[# ]*(de_DE\.UTF-8 UTF-8)/\1/' /etc/locale.gen
 sed -i -E 's/^[# ]*(fr_FR\.UTF-8 UTF-8)/\1/' /etc/locale.gen

 # 3) Generate just the ones you need (this avoids generating tons)
 locale-gen en_US.UTF-8 en_GB.UTF-8 de_DE.UTF-8 fr_FR.UTF-8

 # 4) Verify en_US now exists
 locale -a | grep -i 'en_US\.utf8'

 # 5) Set default
 update-locale LANG=en_US.UTF-8
